# Copy this file to ".env" and fill in your values.
# The .env file is gitignored and never committed.

# TMDB API key — used for movie search in the Add Event sheet.
# Get one free at https://www.themoviedb.org/settings/api
# You can use EITHER a v3 API key OR a v4 Read Access Token (Bearer).
TMDB_API_KEY=83eb7e97b57ba8e00f72120d25263be3

# Password that unlocks dev mode (add/edit/delete). Change this!
DEV_PASSWORD=123123

# Where event data is stored. On Railway, set to your mounted volume, e.g. /data
# DATA_DIR=/data
